# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js — generar con: npx auth secret
AUTH_SECRET="reemplazar-con-secreto-generado"

# Google OAuth — obtener en https://console.cloud.google.com/
AUTH_GOOGLE_ID="tu-google-client-id"
AUTH_GOOGLE_SECRET="tu-google-client-secret"

# URL base de la app
AUTH_URL="http://localhost:3000"

# API de resultados — registrarse en https://dashboard.api-football.com
FOOTBALL_API_KEY="tu-api-key-de-api-football"
